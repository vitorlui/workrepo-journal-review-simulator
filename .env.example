# ---- journal-review-simulator environment ----
# Copy to .env and adjust. Never commit .env.

# ---------- Database ----------
# In Docker, the api/worker use Postgres. For local (non-Docker) runs you may
# leave DATABASE_URL unset to fall back to a local SQLite file (B4).
POSTGRES_USER=jrs
POSTGRES_PASSWORD=jrs_dev_password
POSTGRES_DB=journal_review
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full URL used by the API/worker. Leave empty for local SQLite fallback.
DATABASE_URL=postgresql+psycopg://jrs:jrs_dev_password@postgres:5432/journal_review

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins for the web app.
CORS_ORIGINS=http://localhost:3000

# Root of the documental memory (bind-mounted in Docker).
DATA_DIR=/app/data

# Upload limits
MAX_UPLOAD_MB=50

# ---------- Web ----------
# Browser-visible base URL of the API.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------- AI engines (optional; pipeline defaults to offline templates) ----------
# Default internal engine: "template" (offline, no keys), "claude", or "ollama".
PIPELINE_ENGINE=template
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1
