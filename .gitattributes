# Normalize line endings to LF for cross-platform correctness (B5)
* text=auto eol=lf

# Explicit text types
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.csv   text eol=lf
*.sql   text eol=lf
*.sh    text eol=lf
*.toml  text eol=lf

# Windows scripts keep CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary
*.pdf   binary
*.zip   binary
*.png   binary
*.jpg   binary
*.gguf  binary
